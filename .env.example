# ============================================================
# FarmBridge — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is already in .gitignore).
#
# All VITE_* variables are embedded into the client bundle at build time.
# Do NOT put server-only secrets (database passwords, private API keys,
# Paystack secret keys, etc.) in VITE_* variables — they will be visible
# to anyone who downloads the built JS files.
# ============================================================

# ── Required ────────────────────────────────────────────────

# Base URL of the backend REST API (no trailing slash)
VITE_API_URL=http://localhost:8000

# ── Optional ─────────────────────────────────────────────────

# Google OAuth entry-point URL.
# Defaults to ${VITE_API_URL}/api/auth/google when not set.
# VITE_GOOGLE_OAUTH_URL=

# Sentry DSN for client-side error monitoring.
# Leave unset (or empty) to disable Sentry entirely.
# VITE_SENTRY_DSN=

# Canonical site URL used for SEO <meta> and Open Graph tags.
# VITE_SITE_URL=https://www.farmbridgeafrica.com

# ── Security notes ───────────────────────────────────────────
# Paystack PUBLIC key (pk_live_* / pk_test_*) is safe in VITE_* if needed
# for client-side SDK initialisation, but should still be rotated regularly.
# Paystack SECRET key (sk_live_* / sk_test_*) must NEVER appear here.
